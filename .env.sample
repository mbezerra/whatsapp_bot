# Configuração da API do Groq (Obtenha em console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Caminho para persistência do banco vetorial (ChromaDB)
CHROMA_DB_PATH=./data/chroma_db

# Caminho local para o arquivo consolidado da documentação PHP (.html.gz)
PHP_MANUAL_LOCAL_PATH=./php_doc/php_manual_pt_BR.html.gz

# Token de Autenticação do Twilio (Obrigatório para validação de assinatura em produção)
TWILIO_AUTH_TOKEN=seu_auth_token_aqui

# Modo Debug do Flask (True ou False)
FLASK_DEBUG=True
